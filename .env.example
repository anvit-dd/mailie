# Gmail OAuth2 credentials
# Create at: https://console.cloud.google.com/apis/credentials
# 1. Create OAuth 2.0 Client ID (Web application)
# 2. Add authorized redirect URI: https://your-domain.com/api/auth/callback
GMAIL_CLIENT_ID=your_gmail_client_id_here
GMAIL_CLIENT_SECRET=your_gmail_client_secret_here

# App secret for session cookies (generate with: openssl rand -hex 32)
SESSION_SECRET=generate_a_random_32_byte_hex_string_here

# App URL (for OAuth redirect — must match authorized redirect URI)
APP_URL=http://localhost:3000

# Local credential encryption key (generate with: openssl rand -base64 32)
MAILIE_ENCRYPTION_KEY=generate_a_random_32_byte_base64_string_here
